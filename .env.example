# -----------------------------------------------------------------------------
# Local development environment variables.
# Copy this file to `.env` and adjust if needed — the defaults below work
# out of the box with `docker compose up`. Never commit the real `.env` file.
#
# Two kinds of port variables exist, deliberately kept separate:
#   *_HOST_PORT — the port published on YOUR machine (localhost). Change these
#                 if a default port is already taken on your host. Changing
#                 them never affects container-to-container communication.
#   *_PORT      — the port application services use to REACH a dependency.
#                 Inside the Compose network this is always the dependency's
#                 default port; in production these values (plus the *_HOST
#                 vars) point at real managed services instead. No application
#                 code changes required, only these values.
# -----------------------------------------------------------------------------

# --- PostgreSQL (+ pgvector) ---
POSTGRES_USER=cbir
POSTGRES_PASSWORD=cbir_local_dev_password
POSTGRES_DB=cbir
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333
QDRANT_HTTP_HOST_PORT=6333
QDRANT_GRPC_HOST_PORT=6334

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=cbir_minio_admin
MINIO_ROOT_PASSWORD=cbir_local_dev_password
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001
# Used by services (once they exist) to talk to MinIO via the S3 API contract.
# In production this becomes a real GCS/S3/Azure Blob endpoint + credentials —
# no application code changes required, only these values.
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET_NAME=cbir-catalog-images

# --- auth-service (Milestone 2) ---
AUTH_SERVICE_HOST_PORT=8001
# Local-development secrets only. A real deployment MUST override both from a
# secret manager — never ship these defaults.
AUTH_JWT_SECRET=local-dev-jwt-secret-not-for-production
AUTH_ADMIN_TOKEN=local-dev-admin-token

# --- catalog-service (Milestone 3) ---
CATALOG_SERVICE_HOST_PORT=8002
# Endpoint baked into signed upload/download URLs handed to clients. Clients
# run on the host, so this is the host-published MinIO port — not the
# in-Compose-network "minio:9000" the service itself uses.
S3_PRESIGN_ENDPOINT_URL=http://localhost:9000
