# -----------------------------------------------------------------------------
# Example local override file.
#
# Copy this to `docker-compose.override.yml` (gitignored) for developer-
# specific tweaks — exposed ports, resource limits, mounted source directories
# for hot-reload, etc. — without ever touching the shared docker-compose.yml.
#
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# `docker compose up` picks up docker-compose.override.yml automatically.
# -----------------------------------------------------------------------------

services:
  auth-service:
    # Example: mount source locally for live-reload during development.
    volumes:
      - ./services/auth-service/auth_service:/app/auth_service
    command: ["uvicorn", "auth_service.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  catalog-service:
    # Example: mount source locally for live-reload during development.
    volumes:
      - ./services/catalog-service/catalog_service:/app/catalog_service
    command: ["uvicorn", "catalog_service.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]

  postgres:
    # Example: expose on a non-default host port if 5432 is already in use locally.
    # (Prefer POSTGRES_HOST_PORT in .env; this shows the override mechanism.)
    ports:
      - "5433:5432"
